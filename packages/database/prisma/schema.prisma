generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String?  @unique
  passwordHash    String?
  name            String?
  role            UserRole @default(USER)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  telegramAccount TelegramAccount?
  searchProfiles  SearchProfile[]
  subscriptions   Subscription[]
  favorites       Favorite[]
  notes           UserNote[]
}

model TelegramAccount {
  id         String   @id @default(cuid())
  userId     String   @unique
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  chatId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SearchProfile {
  id                    String   @id @default(cuid())
  userId                String
  name                  String
  isActive              Boolean  @default(true)
  keywords              String[]
  negativeKeywords      String[]
  regions               String[]
  minPrice              Int?
  maxPrice              Int?
  lawTypes              String[]
  purchaseTypes         String[]
  notificationFrequency String   @default("daily")
  notificationTime      String?
  aiAnalysisEnabled     Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  matches TenderMatch[]
}

model Tender {
  id           String   @id @default(cuid())
  source       String
  externalId   String
  title        String
  description  String?
  customerName String?
  customerInn  String?
  price        Int?
  currency     String   @default("RUB")
  region       String?
  lawType      String?
  purchaseType String?
  publishDate  DateTime?
  deadlineDate DateTime?
  status       String?
  url          String?
  documentsUrl String?
  rawData      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matches   TenderMatch[]
  analyses  TenderAiAnalysis[]
  documents TenderDocument[]

  @@unique([source, externalId])
}

model TenderMatch {
  id              String   @id @default(cuid())
  tenderId        String
  searchProfileId String
  userId          String
  score           Int
  status          String   @default("new")
  isHidden        Boolean  @default(false)
  createdAt       DateTime @default(now())

  tender        Tender        @relation(fields: [tenderId], references: [id])
  searchProfile SearchProfile @relation(fields: [searchProfileId], references: [id])
}

model TenderAiAnalysis {
  id                 String   @id @default(cuid())
  tenderId           String
  searchProfileId    String?
  summary            String?
  whatToDeliver      String?
  requirements       Json?
  risks              Json?
  documentsNeeded    Json?
  fitScore           Int?
  recommendation     String?
  recommendationText String?
  rawAiResponse      Json?
  model              String?
  createdAt          DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id])
}

model TenderDocument {
  id        String   @id @default(cuid())
  tenderId  String
  title     String
  url       String?
  filePath  String?
  mimeType  String?
  createdAt DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  tenderId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, tenderId])
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  tenderId  String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  tariffId  String?
  status    String
  startedAt DateTime
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum UserRole {
  USER
  ADMIN
}
